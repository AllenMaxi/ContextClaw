{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ContextClaw Studio",
  "version": "0.1.0",
  "identifier": "com.contextclaw.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173",
    "beforeDevCommand": "npm run tauri:frontend:dev",
    "beforeBuildCommand": "npm run tauri:frontend:build"
  },
  "app": {
    "windows": [
      {
        "title": "ContextClaw Studio",
        "label": "main",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "externalBin": [
      "binaries/contextclaw-studio-daemon"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
